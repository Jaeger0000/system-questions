[
  { type: "mc", topic: "permissions", q: "What does the first character in 'ls -l' output indicate?", choices: ["File size", "File type and permissions", "Owner name", "Creation date"], answer: 1, expl: "-rwxr-xr-x: first char - is file type; remaining 9 chars are permissions" },
  { type: "command", topic: "permissions", q: "Change file permissions to 755 (rwxr-xr-x) using octal notation.", answer: ["chmod 755 filename"], expl: "755 = owner rwx(7), group rx(5), others rx(5)" },
  { type: "command", topic: "permissions", q: "Grant full read, write, execute permissions to owner only (600).", answer: ["chmod 600 filename"], expl: "600 = owner rw(6), group ---(0), others ---(0)" },
  { type: "mc", topic: "permissions", q: "What do the three digits in '644' represent?", choices: ["Owner, group, others permissions in octal", "File size, owner, date", "Read, write, execute counts", "User, group, world levels"], answer: 0, expl: "644 = owner rw(6), group r(4), others r(4)" },
  { type: "command", topic: "permissions", q: "Decode the permission string: -rwxr-x---. Who can write to this file?", answer: ["Only the owner can write"], expl: "rw- for owner (can write); r-- for group (cannot write); --- for others (cannot write)" },
  { type: "mc", topic: "permissions", q: "What does chmod u+x filename do?", choices: ["Remove execute from user", "Add execute permission to owner", "Make all permissions user-only", "Undo all permissions"], answer: 1, expl: "u+x adds execute to owner in symbolic mode" },
  { type: "command", topic: "permissions", q: "Remove write permission from others using symbolic notation.", answer: ["chmod o-w filename"], expl: "o-w removes write from others" },
  { type: "command", topic: "permissions", q: "Set file permissions to rw-r--r-- (owner read/write, group/others read-only).", answer: ["chmod 644 filename"], expl: "644 octal notation" },
  { type: "mc", topic: "permissions", q: "Why is chmod 777 considered dangerous?", choices: ["Slow performance", "Gives everyone full access including write and execute", "Uses too much CPU", "Breaks encryption"], answer: 1, expl: "777 = rwxrwxrwx grants read/write/execute to everyone; any user can modify or execute" },
  { type: "mc", topic: "permissions", q: "What is the difference between chmod 600 and chmod 644?", choices: ["Only owner vs owner+group readable", "600 is for scripts, 644 for data", "644 is older", "No difference"], answer: 0, expl: "600=rw------- (owner only); 644=rw-r--r-- (owner rw, others read-only)" },
  { type: "command", topic: "permissions", q: "Change file ownership to user 'alice' and group 'devteam'.", answer: ["chown alice:devteam filename", "sudo chown alice:devteam filename"], expl: "chown user:group changes owner and group" },
  { type: "mc", topic: "permissions", q: "Why do directories need execute (x) permission?", choices: ["To run directory as script", "To enter/access the directory", "To list directory size", "To compress it"], answer: 1, expl: "Execute on directory allows entering (cd) it; without x, even readable dirs are inaccessible" },
  { type: "command", topic: "permissions", q: "Give read and execute to owner, read-only to group, no access to others for a directory.", answer: ["chmod 750 dirname", "chmod u=rx,g=r,o= dirname"], expl: "750 = rwxr-x--- or 755 for normal directory access" },
  { type: "mc", topic: "permissions", q: "What does 's' mean in permission strings like 'rwsr-xr-x'?", choices: ["Super user", "Set-user-ID (SUID) bit", "Special mode", "Sticky bit"], answer: 1, expl: "SUID bit (s in owner execute position) runs file as owner regardless of who executes it" },

  { type: "command", topic: "file-navigation", q: "Find a file named 'clue.txt' starting from the current directory.", answer: ["find . -name clue.txt", "find . -name 'clue.txt'"], expl: "find . searches from current dir; -name matches filename" },
  { type: "command", topic: "file-navigation", q: "List all files including hidden ones (starting with dot).", answer: ["ls -a", "ls -la"], expl: "-a flag shows hidden files and directories" },
  { type: "command", topic: "file-navigation", q: "Find all files exactly 1024 bytes in size.", answer: ["find . -size 1024c", "find . -size 1024"], expl: "-size 1024c matches files exactly 1024 bytes" },
  { type: "command", topic: "file-navigation", q: "List files with detailed information including file size.", answer: ["ls -l", "ls -la"], expl: "-l flag shows long format with size, date, permissions" },
  { type: "mc", topic: "file-navigation", q: "What does 'ls -l' show in the 5th column?", choices: ["Owner name", "File size in bytes", "Group name", "Modification date"], answer: 1, expl: "5th column after permissions and link count is file size" },
  { type: "command", topic: "file-navigation", q: "Show the last line of a file 'massive_log.txt'.", answer: ["tail -n 1 massive_log.txt", "tail -1 massive_log.txt"], expl: "-n 1 or -1 shows last line only" },

  { type: "mc", topic: "file-operations", q: "What does the 'cp' command do?", choices: ["Change permissions", "Copy file or directory", "Compare files", "Compress"], answer: 1, expl: "cp copies files/directories; cp -r for directories recursively" },
  { type: "command", topic: "file-operations", q: "Copy a file 'settings.cfg' to a 'backup' directory.", answer: ["cp settings.cfg backup/", "cp settings.cfg ./backup/"], expl: "cp source destination; if destination is directory, file is copied into it" },
  { type: "command", topic: "file-operations", q: "Copy a directory 'config' and all its contents to 'config_backup'.", answer: ["cp -r config config_backup"], expl: "-r flag enables recursive copying of directories" },
  { type: "mc", topic: "file-operations", q: "What does the 'mv' command do?", choices: ["Move and rename files", "Make variable", "Monitor viewing", "Move view"], answer: 0, expl: "mv moves/renames files; works within or across directories" },
  { type: "command", topic: "file-operations", q: "Move a file 'misplaced.conf' from 'logs' folder to 'config' folder.", answer: ["mv logs/misplaced.conf config/"], expl: "mv source destination; trailing slash indicates destination is directory" },
  { type: "command", topic: "file-operations", q: "Rename a file 'oldname.txt' to 'newname.txt'.", answer: ["mv oldname.txt newname.txt"], expl: "mv can rename within same directory" },
  { type: "command", topic: "file-operations", q: "Create a new directory named 'backup'.", answer: ["mkdir backup"], expl: "mkdir creates single directory" },
  { type: "command", topic: "file-operations", q: "Create nested directories 'archive/2024/march' all at once.", answer: ["mkdir -p archive/2024/march"], expl: "-p flag creates parent directories as needed" },

  { type: "mc", topic: "symlinks", q: "What is a symbolic link?", choices: ["Hard copy of file", "Pointer/shortcut to another file or directory", "Hidden file", "Symbolic representation"], answer: 1, expl: "Symbolic link (symlink) is like a shortcut; can point to files or directories" },
  { type: "command", topic: "symlinks", q: "Create a symbolic link named 'active_link' pointing to 'settings.cfg'.", answer: ["ln -s settings.cfg active_link"], expl: "ln -s creates symbolic link; syntax: ln -s target linkname" },
  { type: "mc", topic: "symlinks", q: "How do you identify a broken symbolic link using 'ls -l'?", choices: ["Shows 'x' in permissions", "Shows 'l' with pointing to non-existent file", "Shows red background", "Shows 'd' type"], answer: 1, expl: "ls -l shows 'l' type; if target is missing, link shows as broken" },
  { type: "command", topic: "symlinks", q: "Remove a broken symbolic link and create a new one.", answer: ["rm active_link", "ln -s settings.cfg active_link"], expl: "rm deletes symlink; then create new one" },

  { type: "mc", topic: "file-operations", q: "What does 'cat' command do?", choices: ["Change attributes", "Concatenate and print file contents", "Create file", "Copy attributes"], answer: 1, expl: "cat reads and displays file contents; can also concatenate multiple files" },
  { type: "command", topic: "file-operations", q: "Display contents of a file 'secret.txt'.", answer: ["cat secret.txt"], expl: "cat prints file to stdout" },
  { type: "command", topic: "file-operations", q: "Append the contents of 'password.txt' to the end of a file.", answer: ["echo 'password' >> password.txt"], expl: ">> appends to file; > overwrites" },
  { type: "mc", topic: "file-operations", q: "What is the difference between > and >> in redirection?", choices: ["> is faster", "> overwrites, >> appends", "No difference", "> for text, >> for binary"], answer: 1, expl: "> redirects and overwrites file; >> appends to file" },

  { type: "mc", topic: "network-diagnostics", q: "What is an interface in Linux networking?", choices: ["User interface", "Network adapter (physical or virtual)", "Interface language", "Connection interface"], answer: 1, expl: "Interfaces like eth0, wlan0, lo represent network adapters" },
  { type: "command", topic: "network-diagnostics", q: "Display all network interfaces with their MAC addresses.", answer: ["ip link show", "ifconfig", "ip link"], expl: "ip link show lists interfaces with MAC addresses" },
  { type: "command", topic: "network-diagnostics", q: "Show all IP addresses assigned to the system with CIDR notation.", answer: ["ip addr show", "ip address show"], expl: "ip addr show displays IPv4 and IPv6 with /prefix notation" },
  { type: "mc", topic: "network-diagnostics", q: "What is CIDR notation (e.g., /24)?", choices: ["Connection ID", "Classless Inter-Domain Routing notation for subnet mask", "Computer IDentification", "Circular ID Range"], answer: 1, expl: "/24 means 24 bits for network, 8 for hosts (255.255.255.0)" },
  { type: "command", topic: "network-diagnostics", q: "Send exactly 5 ping packets with 1200-byte payload to 8.8.8.8.", answer: ["ping -c 5 -s 1200 8.8.8.8"], expl: "-c count, -s payload size" },
  { type: "command", topic: "network-diagnostics", q: "View the system routing table to find the default gateway.", answer: ["ip route show", "route -n", "netstat -r"], expl: "ip route show displays routes; default gateway is first entry" },
  { type: "command", topic: "network-diagnostics", q: "Ping the default gateway once to check if it is reachable.", answer: ["ping -c 1 gateway_ip"], expl: "-c 1 sends single packet" },
  { type: "command", topic: "network-diagnostics", q: "Display the ARP cache to find MAC address of default gateway.", answer: ["ip neigh show", "arp -a"], expl: "ip neigh (neighbor) shows ARP entries with MAC addresses" },

  { type: "mc", topic: "network-diagnostics", q: "What does the ARP cache store?", choices: ["Routing information", "IP address to MAC address mappings", "DNS records", "Firewall rules"], answer: 1, expl: "ARP cache maps Layer 3 (IP) to Layer 2 (MAC) addresses on local network" },
  { type: "mc", topic: "network-diagnostics", q: "What does REACHABLE mean in ARP cache state?", choices: ["Address is reachable by network", "Neighbor recently verified as reachable", "Connection is ready to break", "Remote host"], answer: 1, expl: "REACHABLE = recently confirmed neighbor; STALE = unconfirmed but usable" },

  { type: "command", topic: "dns-queries", q: "Find Mail Exchange (MX) records for google.com.", answer: ["dig google.com MX", "dig -t MX google.com"], expl: "dig -t MX queries MX records for mail servers" },
  { type: "mc", topic: "dns-queries", q: "What does MX record priority number mean in 'dig' output?", choices: ["Speed rating", "Lower number = higher priority (preferred mail server)", "Port number", "Time to live"], answer: 1, expl: "MX records have priority; lower number is tried first" },
  { type: "command", topic: "dns-queries", q: "Perform a full hierarchical DNS lookup with trace showing root to authoritative.", answer: ["dig google.com +trace"], expl: "+trace shows full DNS resolution chain from root nameserver" },

  { type: "mc", topic: "socket-analysis", q: "What does 'ss' command show?", choices: ["System statistics", "Socket statistics - active/listening network connections", "Shell script", "Super status"], answer: 1, expl: "ss shows sockets (TCP, UDP) state, local/remote addresses, PIDs" },
  { type: "command", topic: "socket-analysis", q: "List all established TCP connections without resolving hostnames.", answer: ["ss -tnp state established", "ss -tn | grep ESTAB"], expl: "-t TCP, -n numeric (no DNS), state established" },
  { type: "command", topic: "socket-analysis", q: "Show all listening TCP ports with the process name using ss.", answer: ["ss -tlnp", "ss -tlp"], expl: "-l listening, -n numeric, -p process" },
  { type: "mc", topic: "socket-analysis", q: "What does 'LISTEN' state mean for a socket?", choices: ["Connection waiting to send", "Server is accepting incoming connections on this port", "Client is sending", "Socket error"], answer: 1, expl: "LISTEN = server socket waiting for connections" },

  { type: "command", topic: "file-operations", q: "Check if a file has read permission before attempting to read it.", answer: ["test -r filename && echo 'readable' || echo 'not readable'"], expl: "-r tests read permission; && runs if true, || if false" },
  { type: "mc", topic: "file-operations", q: "What does the 'file' command do?", choices: ["Create file", "Determine file type and encoding", "Find file", "File operations"], answer: 1, expl: "file identifies file type (text, binary, script, etc.)" },
  { type: "command", topic: "file-operations", q: "Find all executable files in current directory.", answer: ["find . -type f -executable"], expl: "-type f regular file, -executable has execute bit set" },

  { type: "mc", topic: "permissions", q: "What is the 'setuid' bit (SUID)?", choices: ["Super user ID", "Special permission bit that runs file as owner", "Security user ID", "Set user identity"], answer: 1, expl: "SUID (shown as 's' in owner execute position) runs file with owner privileges" },
  { type: "command", topic: "permissions", q: "Set the SUID bit on a file 'app'.", answer: ["chmod u+s app", "chmod 4755 app"], expl: "u+s adds SUID; 4755 = SUID + rwxr-xr-x" },
  { type: "mc", topic: "permissions", q: "What does sticky bit (t) do on a directory?", choices: ["Marks directory as sticky", "Only owner can delete own files", "Compress directory", "Make directory read-only"], answer: 1, expl: "Sticky bit on directory prevents users from deleting others' files" },
  { type: "command", topic: "permissions", q: "Set sticky bit on /tmp directory.", answer: ["chmod +t /tmp", "chmod 1777 /tmp"], expl: "+t adds sticky bit; 1777 = sticky + rwxrwxrwx" },

  { type: "output", topic: "file-operations", q: "What does: ls -la | grep '^d' output?", answer: ["Lines starting with 'd' - all directories in current folder"], expl: "^d matches lines starting with 'd' (directory type)" },
  { type: "command", topic: "file-navigation", q: "Show all files modified in the last 24 hours.", answer: ["find . -type f -mtime -1"], expl: "-mtime -1 = modified less than 1 day ago" },
  { type: "command", topic: "file-navigation", q: "Find all .log files and display their sizes.", answer: ["find . -name '*.log' -exec ls -lh {} \\;"], expl: "-exec runs command on each result" },

  { type: "mc", topic: "network-diagnostics", q: "What is the significance of TTL in ping output?", choices: ["Type of Transfer Layer", "Time To Live - hops remaining before packet discarded", "Total Transfer Length", "Transport Type"], answer: 1, expl: "TTL decrements at each hop; when 0, packet is dropped and error sent back" },
  { type: "command", topic: "network-diagnostics", q: "Trace the path to 1.1.1.1 using ICMP (instead of default UDP).", answer: ["traceroute -I 1.1.1.1"], expl: "-I flag uses ICMP Echo instead of UDP probes" },
