[
  { type: "mc", topic: "awk-basics", q: "What is awk?", choices: ["A shell scripting language", "A domain-specific language for pattern scanning and processing text", "An archive tool", "A networking utility"], answer: 1, expl: "awk reads input line-by-line, splits into fields, applies actions to matching patterns" },
  { type: "mc", topic: "awk-basics", q: "Who are the three creators of awk?", choices: ["Aho, Weinberger, Kernighan", "Torvalds, Ritchie, Thompson", "Stallman, Cox, Joy", "Stroustrup, Gorelick, Koenig"], answer: 0, expl: "Alfred Aho, Peter Weinberger, Brian Kernighan created awk at Bell Labs in 1977" },
  { type: "mc", topic: "awk-basics", q: "When was awk released with Unix?", choices: ["1975", "1977", "1979", "1981"], answer: 2, expl: "awk was released with Unix v7 in 1979 and became POSIX-standardized" },
  { type: "mc", topic: "awk-basics", q: "What is the main strength of awk?", choices: ["Speed", "Conciseness and field-awareness — one-liners replace dozens of code lines", "Graphics support", "Networking capabilities"], answer: 1, expl: "awk treats input as records/fields automatically; pattern-action paradigm is elegant" },

  { type: "mc", topic: "awk-fields", q: "What does $1 represent in awk?", choices: ["First line", "First field of current record", "First argument", "Line number"], answer: 1, expl: "$1 is first field; $0 is entire line; access with $1, $2, $3, etc." },
  { type: "mc", topic: "awk-fields", q: "What does $0 represent?", choices: ["First field", "Current record number", "Entire current record/line", "Zero field"], answer: 2, expl: "$0 is the whole line; $1 is first field, $2 is second, etc." },
  { type: "mc", topic: "awk-fields", q: "What is NF in awk?", choices: ["No Field", "Next Field", "Number of Fields on current record", "Name Field"], answer: 2, expl: "NF holds count of fields; useful to access last field with $NF" },
  { type: "mc", topic: "awk-fields", q: "What is NR in awk?", choices: ["No Record", "Number of Records/current line number", "Next Row", "Named Record"], answer: 1, expl: "NR increments for each line; useful in END block for counting and averaging" },
  { type: "command", topic: "awk-fields", q: "Print the first field of each line.", answer: ["awk '{print $1}' filename"], expl: "$1 extracts first field; fields auto-split by whitespace" },
  { type: "command", topic: "awk-fields", q: "Print both first and third fields separated by a tab.", answer: ["awk '{print $1, $3}' filename"], expl: "Comma in print separates output by OFS (default space)" },
  { type: "output", topic: "awk-fields", q: "Given input 'alice 28 engineer', what does awk '{print $2}' output?", answer: ["28"], expl: "$2 is second field" },
  { type: "mc", topic: "awk-fields", q: "How does awk split input into fields by default?", choices: ["By comma", "By whitespace (spaces/tabs)", "By colon", "By newline"], answer: 1, expl: "Default field separator (FS) is whitespace; change with -F flag" },
  { type: "command", topic: "awk-fields", q: "Access the last field of each line using NF.", answer: ["awk '{print $NF}' filename"], expl: "$NF references last field regardless of field count" },

  { type: "mc", topic: "awk-syntax", q: "What is the basic awk syntax?", choices: ["awk file", "awk 'pattern' file", "awk 'pattern { action }' file", "awk pattern action file"], answer: 2, expl: "Pattern and action are optional separately; awk automatically reads from stdin if no file" },
  { type: "mc", topic: "awk-syntax", q: "What happens if pattern is omitted?", choices: ["Error", "No lines processed", "All lines match the pattern", "Only first line processed"], answer: 2, expl: "Omit pattern to match all records; omit action to default to { print $0 }" },
  { type: "mc", topic: "awk-syntax", q: "What happens if action is omitted?", choices: ["Pattern is ignored", "Default action is { print $0 }", "Error", "No output"], answer: 1, expl: "Omit action to print entire matching record" },
  { type: "command", topic: "awk-syntax", q: "Run an awk command on a file with colon-separated fields.", answer: ["awk -F':' '{print $1, $7}' filename"], expl: "-F flag sets field separator" },
  { type: "mc", topic: "awk-syntax", q: "Can awk read from stdin?", choices: ["No, file required", "Yes, omit filename or use stdin", "Only with -i flag", "Not recommended"], answer: 1, expl: "awk works in pipelines; omit filename to read stdin" },
  { type: "command", topic: "awk-syntax", q: "Use awk in a pipeline to process output from another command.", answer: ["command | awk 'pattern { action }'"], expl: "awk can read from pipes; powerful in Unix command chains" },

  { type: "mc", topic: "awk-variables", q: "What is FS in awk?", choices: ["First Statement", "Field Separator — sets how fields are split", "Field String", "File Size"], answer: 1, expl: "FS controls field splitting; default is whitespace" },
  { type: "mc", topic: "awk-variables", q: "What is RS in awk?", choices: ["Record String", "Record Separator — sets line delimiter", "Request Status", "Reset String"], answer: 1, expl: "RS defines record boundaries; default is newline" },
  { type: "mc", topic: "awk-variables", q: "What is OFS in awk?", choices: ["Output Field Separator — controls spacing in output", "Old Field Separator", "Optional Fields", "Output File String"], answer: 0, expl: "OFS is inserted between fields when printing; default is space" },
  { type: "mc", topic: "awk-variables", q: "What is ORS in awk?", choices: ["Old Record String", "Output Record Separator — added at end of each print", "Output Result Status", "Optional Record Separator"], answer: 1, expl: "ORS terminates each print statement; default is newline" },
  { type: "command", topic: "awk-variables", q: "Set the field separator to comma in BEGIN block.", answer: ["awk 'BEGIN { FS=\",\" } { print $1 }' filename"], expl: "Set FS in BEGIN before processing starts" },
  { type: "output", topic: "awk-variables", q: "In a CSV with 3 fields, what does NF equal?", answer: ["3"], expl: "NF counts fields in current record" },

  { type: "mc", topic: "awk-lifecycle", q: "What are the three phases of awk execution?", choices: ["Read, Process, Output", "BEGIN, MAIN, END", "Parse, Execute, Return", "Input, Filter, Print"], answer: 1, expl: "BEGIN runs first, MAIN for each record, END after all input processed" },
  { type: "mc", topic: "awk-lifecycle", q: "When does BEGIN block execute?", choices: ["For each record", "Before any input is read", "After all records processed", "Only if pattern matches"], answer: 1, expl: "BEGIN is perfect for initialization and headers" },
  { type: "mc", topic: "awk-lifecycle", q: "When does END block execute?", choices: ["For each record", "Never", "After all input processed", "Before BEGIN"], answer: 2, expl: "END block is ideal for printing totals and summaries" },
  { type: "command", topic: "awk-lifecycle", q: "Count total lines and print count after all input.", answer: ["awk 'BEGIN { count=0 } { count++ } END { print count }' filename"], expl: "Initialize in BEGIN, accumulate in main, report in END" },
  { type: "output", topic: "awk-lifecycle", q: "What does this program output: awk 'BEGIN { print \"start\" } { print } END { print \"done\" }'?", answer: ["start (header), then all lines, then done (footer)"], expl: "BEGIN runs first, main loop processes each line, END runs last" },

  { type: "mc", topic: "awk-patterns", q: "What does /regex/ pattern match?", choices: ["Literal slash", "Lines matching the regular expression", "First field", "Field count"], answer: 1, expl: "Regex patterns filter records; /ERROR/ matches lines containing ERROR" },
  { type: "command", topic: "awk-patterns", q: "Print only lines starting with ERROR or WARN.", answer: ["awk '/^(ERROR|WARN)/ { print }' filename"], expl: "Regex pattern filters matching records" },
  { type: "mc", topic: "awk-patterns", q: "What does ~ operator do?", choices: ["Field assignment", "Regex match against specific field", "String concatenation", "Field separator"], answer: 1, expl: "$3 ~ /Engineer/ matches if field 3 contains Engineer" },
  { type: "command", topic: "awk-patterns", q: "Filter rows where the second field matches 'Engineer'.", answer: ["awk '$2 ~ /Engineer/ { print }' filename"], expl: "~ matches field against regex pattern" },
  { type: "mc", topic: "awk-patterns", q: "What does !~ operator do?", choices: ["Negation", "Does NOT match regex", "Field exists", "String equals"], answer: 1, expl: "$3 !~ /Manager/ prints lines where field 3 does NOT contain Manager" },
  { type: "command", topic: "awk-patterns", q: "Print lines where second field does NOT equal 'Designer'.", answer: ["awk '$2 !~ /Designer/ { print }' filename"], expl: "!~ is the negated match operator" },
  { type: "mc", topic: "awk-patterns", q: "Can patterns be numeric comparisons?", choices: ["No, only regex", "Yes, like $2 > 1000", "Only with BEGIN", "Not in awk"], answer: 1, expl: "Patterns can be regex, numeric, or any expression" },
  { type: "command", topic: "awk-patterns", q: "Filter rows where second field is greater than 1000.", answer: ["awk '$2 > 1000 { print }' filename"], expl: "Numeric pattern filters based on field value" },

  { type: "mc", topic: "awk-arrays", q: "What are awk arrays?", choices: ["Lists of variables", "String-indexed associative arrays", "Numeric arrays only", "Fixed-size arrays"], answer: 1, expl: "awk arrays are indexed by strings; count[key]++ idiom counts occurrences" },
  { type: "command", topic: "awk-arrays", q: "Count occurrences of values in third field and print totals.", answer: ["awk '{ count[$3]++ } END { for (r in count) print r, count[r] }' filename"], expl: "Associative arrays group by key; iterate in END" },
  { type: "output", topic: "awk-arrays", q: "What does this output: awk '{ count[$2]++ } END { for (r in count) print r }' with input 'engineer engineer designer'?", answer: ["engineer", "designer"], expl: "Array counts by field; prints unique values" },
  { type: "mc", topic: "awk-arrays", q: "How do you iterate over array elements?", choices: ["for (i=1; i<=size; i++)", "for (key in array)", "while loop", "foreach"], answer: 1, expl: "for (k in arr) syntax iterates over all keys" },
  { type: "command", topic: "awk-arrays", q: "Sum sales amounts by region and print totals in END block.", answer: ["awk '{ total[$2] += $3 } END { for (r in total) print r, total[r] }' filename"], expl: "Associative arrays accumulate values by key" },

  { type: "mc", topic: "awk-printf", q: "What is the difference between print and printf?", choices: ["No difference", "printf allows format control; print always adds newline", "printf is faster", "print is old"], answer: 1, expl: "printf doesn't add newline automatically; use \\n for line breaks" },
  { type: "mc", topic: "awk-printf", q: "What does %-10s format?", choices: ["Right-aligned 10 chars", "Left-aligned 10-char string", "Uppercase string", "String with spaces"], answer: 1, expl: "%-10s left-aligns; %10s right-aligns; 10 is width" },
  { type: "mc", topic: "awk-printf", q: "What does %8.2f format?", choices: ["8 digits total, 2 after decimal", "Right-aligned float, 2 decimals, 8-char width", "Scientific notation", "Float with 8 decimal places"], answer: 1, expl: "%8.2f = right-aligned, 8 chars total width, 2 decimal precision" },
  { type: "command", topic: "awk-printf", q: "Print formatted table with aligned columns using printf.", answer: ["awk '{ printf \"%-10s %8.2f\\n\", $1, $2 }' filename"], expl: "printf controls alignment and precision for professional reports" },
  { type: "output", topic: "awk-printf", q: "What does printf \"%-5s %3d\\n\", \"john\", 30 output?", answer: ["john   30"], expl: "%-5s left-aligns 'john' in 5 chars; %3d right-aligns 30" },

  { type: "mc", topic: "awk-real-world", q: "What is a common real-world use of awk?", choices: ["Replacing entire programming languages", "Log file analysis", "Graphic design", "Network routing"], answer: 1, expl: "awk excels at parsing logs, extracting fields, counting/grouping data" },
  { type: "command", topic: "awk-real-world", q: "Extract username and shell from /etc/passwd (colon-separated).", answer: ["awk -F':' '{ print $1, $7 }' /etc/passwd"], expl: "-F':' sets field separator to colon" },
  { type: "mc", topic: "awk-real-world", q: "What is the typical pipeline pattern for awk?", choices: ["awk alone is sufficient", "awk | sort | uniq | head — group, order, report", "awk | sed | grep only", "awk | cat only"], answer: 1, expl: "Combine awk for grouping, sort for ordering, head for top-N results" },
  { type: "command", topic: "awk-real-world", q: "Find top 5 IP addresses by request count from an access log.", answer: ["awk '{ count[$1]++ } END { for (ip in count) print count[ip], ip }' access.log | sort -rn | head -5"], expl: "awk groups by IP, sort orders by count, head limits to 5" },
  { type: "mc", topic: "awk-real-world", q: "How do you save an awk program for reuse?", choices: ["Can't be saved", "Save as .awk file and use awk -f script.awk", "Embed in shell script", "Never reused"], answer: 1, expl: "awk -f script.awk file processes using saved program" },
  { type: "mc", topic: "awk-real-world", q: "When processing CSV files with awk, where should you set FS?", choices: ["In main loop", "In END block", "In BEGIN block before processing starts", "Using -F flag only"], answer: 2, expl: "Set FS in BEGIN { FS=\",\" } before any records are read" },
  { type: "command", topic: "awk-real-world", q: "Process CSV file with comma-separated fields, skip header, sum amounts by region.", answer: ["awk 'BEGIN { FS=\",\" } NR > 1 { total[$2] += $3 } END { for (r in total) print r, total[r] }' sales.csv"], expl: "BEGIN sets FS; NR > 1 skips header; END reports totals" },

  { type: "mc", topic: "awk-advanced", q: "What does NR > 1 do?", choices: ["Matches records with more than 1 field", "Matches all records except first (header)", "Filters to records 2+", "Line numbers greater than 1"], answer: 1, expl: "NR > 1 skips header row in CSV processing" },
  { type: "command", topic: "awk-advanced", q: "Print only lines where column 2 is numeric and greater than 100.", answer: ["awk '$2 > 100 { print }' filename"], expl: "Numeric comparison on field values" },
  { type: "output", topic: "awk-advanced", q: "What does: awk '{ sum += $2 } END { print sum }' with input '10 20 30' output?", answer: ["60"], expl: "Sum accumulates field 2 from all three lines" },
  { type: "command", topic: "awk-advanced", q: "Calculate average of second column.", answer: ["awk '{ sum += $2; count++ } END { print sum/count }' filename"], expl: "Accumulate sum and count, divide in END" },
  { type: "mc", topic: "awk-advanced", q: "What does && operator do in awk?", choices: ["Bitwise AND", "Logical AND — both conditions must be true", "String concatenation", "Array membership"], answer: 1, expl: "$2 > 30 && $3 ~ /Engineer/ requires both conditions true" },
  { type: "command", topic: "awk-advanced", q: "Filter rows where age > 30 AND role is Engineer.", answer: ["awk '$2 > 30 && $3 ~ /Engineer/ { print }' filename"], expl: "&& requires both conditions to match" },
  { type: "mc", topic: "awk-advanced", q: "What does || operator do?", choices: ["Bitwise OR", "Logical OR — either condition true", "String OR", "Field list"], answer: 1, expl: "$3 == \"A\" || $3 == \"B\" matches if field is A or B" },
  { type: "command", topic: "awk-advanced", q: "Print lines where status is either 'active' or 'pending'.", answer: ["awk '$2 == \"active\" || $2 == \"pending\" { print }' filename"], expl: "|| checks either condition" },
  { type: "mc", topic: "awk-advanced", q: "What is a pro move when using awk for reports?", choices: ["Use print only", "Use printf for alignment and precision", "Never use BEGIN/END", "Avoid pipes"], answer: 1, expl: "printf gives professional alignment; essential for readable reports" },
  { type: "flags", topic: "awk-flags", q: "Explain common awk command options.", flags: [
    { flag: "-F", answer: ["Set field separator (e.g., -F',' for CSV)"] },
    { flag: "-f", answer: ["Read awk program from file (e.g., awk -f script.awk)"] },
    { flag: "-v", answer: ["Set variable before execution (e.g., -v var=value)"] }
  ], expl: "-F changes field splitting; -f loads script from file; -v initializes variables" }
]