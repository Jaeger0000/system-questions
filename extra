  { type: "mc", topic: "networking", q: "Which layer handles MAC addresses?", choices: ["Layer 3 (Network)", "Layer 2 (Data Link)", "Layer 4 (Transport)", "Layer 7 (Application)"], answer: 1, expl: "Layer 2 (Data Link) uses MAC addresses for local network communication" },
  { type: "mc", topic: "networking", q: "What does TTL (Time To Live) do?", choices: ["Track transfer time", "Limit hop count - prevent infinite loops", "Transfer large files", "Timeout length"], answer: 1, expl: "TTL decrements at each router; packet discarded at TTL=0 (prevents loops)" }
