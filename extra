  { type: "command", topic: "networking", q: "List all network namespaces on the system.", answer: ["ip netns list"], expl: "ip netns list shows all namespace names" },
  { type: "command", topic: "networking", q: "Create a new network namespace called 'test_ns'.", answer: ["ip netns add test_ns"], expl: "ip netns add creates a namespace" },

